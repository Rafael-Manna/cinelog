<%- include('partials/header', { titulo: post.titulo }) %>

<article class="card post-detalhe">
  <div class="post-autor">
    <%- include('partials/avatar', { user: post.User, tamanho: 'md' }) %>
    <div class="post-autor-info">
      <span class="autor-nome"><%= post.User.nome %></span>
      <span class="muted"><%= new Date(post.createdAt).toLocaleString('pt-BR') %></span>
    </div>
    <%- include('partials/estrelas', { nota: post.nota }) %>
  </div>

  <div class="post-detalhe-corpo">
    <% if (post.posterUrl) { %>
      <img src="<%= post.posterUrl %>" alt="poster de <%= post.titulo %>" class="post-poster-hero">
    <% } %>

    <div class="post-detalhe-texto">
      <div class="post-head" style="margin-top: 0.8rem">
        <span class="tag"><%= post.categoria %></span>
      </div>

      <h1><%= post.titulo %></h1>
      <div class="conteudo"><%= post.conteudo %></div>

      <% if (usuario && usuario.id === post.User.id) { %>
        <div class="acoes">
          <a href="/posts/<%= post.id %>/editar" class="btn btn-secondary">Editar</a>
          <form action="/posts/<%= post.id %>/excluir" method="POST" class="inline-form" onsubmit="return confirm('Excluir publicacao?');">
            <button type="submit" class="btn btn-danger">Excluir</button>
          </form>
        </div>
      <% } %>
    </div>
  </div>
</article>

<section class="card">
  <h2>Comentarios (<%= post.Comments.length %>)</h2>

  <form action="/comentarios/post/<%= post.id %>" method="POST" class="form-comentario">
    <textarea name="conteudo" rows="3" placeholder="Escreva um comentario..." required></textarea>
    <button type="submit" class="btn btn-primary">Comentar</button>
  </form>

  <% if (!post.Comments.length) { %>
    <p class="muted">Sem comentarios ainda.</p>
  <% } %>

  <ul class="comentarios">
    <% post.Comments.forEach(c => { %>
      <li class="comentario">
        <%- include('partials/avatar', { user: c.User, tamanho: 'sm' }) %>
        <div class="comentario-corpo">
          <div class="comentario-head">
            <span class="autor-nome-sm"><%= c.User.nome %></span>
            <span class="muted"><%= new Date(c.createdAt).toLocaleString('pt-BR') %></span>
          </div>
          <p><%= c.conteudo %></p>

          <% if (usuario && usuario.id === c.User.id) { %>
            <form action="/comentarios/<%= c.id %>/excluir" method="POST" class="inline-form" onsubmit="return confirm('Excluir comentario?');">
              <button type="submit" class="btn-link danger">excluir</button>
            </form>
          <% } %>
        </div>
      </li>
    <% }) %>
  </ul>
</section>

<%- include('partials/footer') %>
