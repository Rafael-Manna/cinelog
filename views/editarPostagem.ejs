<%- include('partials/header', { titulo: 'Editar publicacao' }) %>

<div class="card">
  <h1>Editar publicacao</h1>
  <form action="/posts/<%= post.id %>/editar" method="POST">
    <label>Titulo
      <input type="text" name="titulo" value="<%= post.titulo %>" required>
    </label>
    <label>Categoria
      <input type="text" name="categoria" value="<%= post.categoria %>" required>
    </label>
    <label>Nota
      <select name="nota" required>
        <% for (let i = 1; i <= 5; i++) { %>
          <option value="<%= i %>" <%= post.nota === i ? 'selected' : '' %>><%= i %></option>
        <% } %>
      </select>
    </label>
    <label>Conteudo
      <textarea name="conteudo" rows="6" required><%= post.conteudo %></textarea>
    </label>
    <button type="submit" class="btn btn-primary">Salvar</button>
    <a href="/posts/<%= post.id %>" class="btn btn-secondary">Cancelar</a>
  </form>
</div>

<%- include('partials/footer') %>
