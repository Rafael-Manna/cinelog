<%- include('partials/header', { titulo: usuarioPerfil.nome }) %>

<div class="card">
  <div class="perfil-topo">
    <%- include('partials/avatar', { user: usuarioPerfil, tamanho: 'lg' }) %>
    <div class="perfil-info">
      <h1><%= usuarioPerfil.nome %></h1>
      <% if (usuarioPerfil.bio) { %>
        <p class="bio"><%= usuarioPerfil.bio %></p>
      <% } %>

      <div class="perfil-stats">
        <span><strong><%= totalSeguidores %></strong> seguidores</span>
        <span><strong><%= totalSeguindo %></strong> seguindo</span>
        <span><strong><%= usuarioPerfil.Posts.length %></strong> avaliacoes</span>
      </div>

      <%# Botoes: seguir / parar de seguir / editar perfil (caso seja o seu) %>
      <div class="perfil-acoes">
        <% if (ehProprioPerfil) { %>
          <a href="/perfil" class="btn btn-secondary">Editar perfil</a>
        <% } else if (jaSegue) { %>
          <form action="/usuarios/<%= usuarioPerfil.id %>/parar-de-seguir" method="POST" class="inline-form">
            <button type="submit" class="btn btn-secondary">Deixar de seguir</button>
          </form>
        <% } else { %>
          <form action="/usuarios/<%= usuarioPerfil.id %>/seguir" method="POST" class="inline-form">
            <button type="submit" class="btn btn-primary">Seguir</button>
          </form>
        <% } %>
      </div>
    </div>
  </div>
</div>

<div class="card">
  <h2>Avaliacoes de <%= usuarioPerfil.nome %></h2>

  <% if (!usuarioPerfil.Posts.length) { %>
    <p class="muted">Esse usuario ainda nao publicou nenhuma avaliacao.</p>
  <% } %>

  <div class="post-list">
    <% usuarioPerfil.Posts.forEach(post => { %>
      <article class="post-card-mini">
        <% if (post.posterUrl) { %>
          <a href="/posts/<%= post.id %>" class="post-poster-link">
            <img src="<%= post.posterUrl %>" alt="poster" class="post-poster-thumb-sm">
          </a>
        <% } %>
        <div class="post-card-mini-info">
          <div class="post-head">
            <span class="tag"><%= post.categoria %></span>
            <%- include('partials/estrelas', { nota: post.nota }) %>
          </div>
          <h3><a href="/posts/<%= post.id %>"><%= post.titulo %></a></h3>
          <p class="muted"><%= new Date(post.createdAt).toLocaleString('pt-BR') %></p>
          <p class="conteudo-resumo"><%= post.conteudo.length > 150 ? post.conteudo.slice(0, 150) + '...' : post.conteudo %></p>
        </div>
      </article>
    <% }) %>
  </div>
</div>

<%- include('partials/footer') %>
