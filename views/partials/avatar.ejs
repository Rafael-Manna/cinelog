<%
  const tam = (typeof tamanho !== 'undefined') ? tamanho : 'md';
  const cores = ['#e57373', '#ba68c8', '#7986cb', '#4fc3f7', '#4db6ac',
                 '#81c784', '#dce775', '#ffd54f', '#ffb74d', '#a1887f'];
  const cor = cores[user.id % cores.length];
  const inicial = user.nome ? user.nome.charAt(0).toUpperCase() : '?';
%>
<% if (user.avatarUrl) { %>
  <img src="<%= user.avatarUrl %>" alt="<%= user.nome %>" class="avatar avatar-<%= tam %>">
<% } else { %>
  <span class="avatar avatar-<%= tam %> avatar-placeholder" style="background:<%= cor %>"><%= inicial %></span>
<% } %>
